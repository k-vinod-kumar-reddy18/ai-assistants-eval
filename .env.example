# Copy to .env and fill in your values

# Frontier backend
ANTHROPIC_API_KEY=sk-ant-...

# OSS backend — choose provider
OSS_PROVIDER=ollama          # ollama | hf | spaces
HF_TOKEN=hf_...              # for HuggingFace Inference API
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# HF Spaces deployed endpoint (if OSS_PROVIDER=spaces)
OSS_ENDPOINT=https://your-username-qwen-assistant.hf.space/api/predict

# Frontend
VITE_OSS_API=http://localhost:8001
VITE_FRONTIER_API=http://localhost:8002
